  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --primary: #1a3a5c;
      --primary-dark: #122840;
      --accent: #c9a84c;
      --bg: #f0f4f8;
      --card: #ffffff;
      --text: #1e2d3d;
      --muted: #6b7c93;
      --border: #d1dce8;
      --success: #1a6e34;
      --danger: #b83228;
      --radius: 12px;
      --shadow: 0 8px 40px rgba(26,58,92,0.13);
    }

    body {
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    .tela { display: none; }
    .tela.ativa {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    /* ══ BOAS-VINDAS ══ */
    #tela-boas-vindas {
      min-height: 100vh;
      justify-content: center;
      padding: 40px 20px;
      background: linear-gradient(145deg, var(--primary-dark) 0%, var(--primary) 60%, #2a5a8c 100%);
      position: relative;
      overflow: hidden;
    }

    #tela-boas-vindas::before {
      content: '';
      position: absolute;
      width: 600px; height: 600px;
      border-radius: 50%;
      background: rgba(201,168,76,0.07);
      top: -200px; right: -150px;
      pointer-events: none;
    }

    #tela-boas-vindas::after {
      content: '';
      position: absolute;
      width: 400px; height: 400px;
      border-radius: 50%;
      background: rgba(201,168,76,0.05);
      bottom: -100px; left: -100px;
      pointer-events: none;
    }

    .bv-inner {
      position: relative;
      z-index: 1;
      text-align: center;
      max-width: 620px;
      width: 100%;
    }

    .bv-logo {
      width: 68px; height: 68px;
      background: linear-gradient(135deg, var(--accent), #e8c870);
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 28px;
      font-size: 30px;
      box-shadow: 0 8px 28px rgba(201,168,76,0.38);
    }

    .bv-badge {
      display: inline-block;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.32);
      color: var(--accent);
      font-size: 0.71rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 5px 18px;
      border-radius: 999px;
      margin-bottom: 22px;
    }

    .bv-inner h1 {
      font-size: clamp(1.75rem, 5vw, 2.7rem);
      color: #fff;
      font-weight: 800;
      line-height: 1.15;
      margin-bottom: 18px;
    }

    .bv-inner h1 span { color: var(--accent); }

    .bv-sub {
      font-size: 1.02rem;
      color: rgba(255,255,255,0.70);
      line-height: 1.72;
      margin-bottom: 36px;
      max-width: 480px;
      margin-left: auto;
      margin-right: auto;
    }

    .bv-features {
      display: flex;
      justify-content: center;
      gap: 28px;
      flex-wrap: wrap;
      margin-bottom: 40px;
    }

    .bv-feature {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.82rem;
      color: rgba(255,255,255,0.58);
    }

    .bv-feature .dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      flex-shrink: 0;
    }

    .btn-iniciar {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, var(--accent), #e8c870);
      color: var(--primary-dark);
      font-size: 1rem;
      font-weight: 700;
      padding: 16px 48px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      box-shadow: 0 8px 28px rgba(201,168,76,0.42);
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
    }

    .btn-iniciar:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 38px rgba(201,168,76,0.52);
    }

    .bv-disclaimer {
      margin-top: 22px;
      font-size: 0.74rem;
      color: rgba(255,255,255,0.32);
    }

    /* ══ FORMULÁRIO ══ */
    #tela-formulario {
      min-height: 100vh;
      padding: 40px 16px 80px;
    }

    .form-topbar {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.77rem;
      font-weight: 700;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 22px;
      max-width: 660px;
      width: 100%;
    }

    .dot-gold {
      width: 9px; height: 9px;
      background: var(--accent);
      border-radius: 50%;
      flex-shrink: 0;
    }

    .progress-wrap {
      width: 100%;
      max-width: 660px;
      margin-bottom: 22px;
    }

    .progress-meta {
      display: flex;
      justify-content: space-between;
      font-size: 0.77rem;
      color: var(--muted);
      margin-bottom: 8px;
    }

    .progress-bar {
      height: 5px;
      background: var(--border);
      border-radius: 999px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--primary), var(--accent));
      border-radius: 999px;
      transition: width 0.55s cubic-bezier(.4,0,.2,1);
      width: 10%;
    }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 40px 44px;
      width: 100%;
      max-width: 660px;
      border-top: 4px solid var(--accent);
    }

    .step { display: none; }
    .step.ativo {
      display: block;
      animation: fadeUp 0.28s ease;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(10px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .step-tag {
      font-size: 0.70rem;
      font-weight: 700;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 10px;
    }

    .step h2 {
      font-size: 1.16rem;
      color: var(--primary);
      font-weight: 700;
      line-height: 1.35;
      margin-bottom: 6px;
    }

    .step .hint {
      font-size: 0.83rem;
      color: var(--muted);
      margin-bottom: 24px;
      line-height: 1.55;
    }

    .input-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-bottom: 18px;
    }

    .input-group label {
      font-size: 0.83rem;
      font-weight: 600;
      color: var(--text);
    }

    .input-group label .req { color: var(--accent); margin-left: 2px; }
    .input-group label .opt {
      font-size: 0.74rem;
      color: var(--muted);
      font-weight: 400;
      margin-left: 4px;
    }

    .field-input {
      padding: 13px 16px;
      border: 2px solid var(--border);
      border-radius: 8px;
      font-size: 0.94rem;
      color: var(--text);
      background: #fafbfc;
      outline: none;
      transition: border-color 0.2s, background 0.2s;
      width: 100%;
      font-family: inherit;
    }

    .field-input:focus { border-color: var(--primary); background: #fff; }
    .field-input.erro { border-color: var(--danger); }

    .field-error {
      font-size: 0.76rem;
      color: var(--danger);
      display: none;
    }

    .field-error.visivel { display: block; }

    .options { display: flex; flex-direction: column; gap: 11px; }

    .option-btn {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 18px;
      border: 2px solid var(--border);
      border-radius: var(--radius);
      background: #fafbfc;
      cursor: pointer;
      font-size: 0.92rem;
      color: var(--text);
      text-align: left;
      transition: border-color 0.18s, background 0.18s, transform 0.12s;
      width: 100%;
      font-family: inherit;
    }

    .option-btn:hover {
      border-color: var(--accent);
      background: #fdf8ee;
      transform: translateY(-1px);
    }

    .option-btn.sel {
      border-color: var(--primary);
      background: #eaf0f8;
    }

    .opt-radio {
      width: 20px; height: 20px;
      border-radius: 50%;
      border: 2px solid var(--border);
      flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.18s;
    }

    .option-btn.sel .opt-radio {
      background: var(--primary);
      border-color: var(--primary);
    }

    .option-btn.sel .opt-radio::after {
      content: '';
      width: 7px; height: 7px;
      background: #fff;
      border-radius: 50%;
      display: block;
    }

    .scale-wrap { display: flex; flex-direction: column; gap: 12px; }
    .scale-buttons { display: flex; gap: 7px; flex-wrap: wrap; }

    .scale-btn {
      width: 46px; height: 46px;
      border-radius: 9px;
      border: 2px solid var(--border);
      background: #fafbfc;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      color: var(--text);
      transition: all 0.15s;
      font-family: inherit;
    }

    .scale-btn:hover { border-color: var(--accent); background: #fdf8ee; }
    .scale-btn.sl { border-color: #9baab7; background: #eef1f4; color: #5a6a7a; }
    .scale-btn.sw { border-color: #d97706; background: #fef3e2; color: #b45309; }
    .scale-btn.sh { border-color: var(--success); background: #e8f5ee; color: var(--success); }

    .scale-legend {
      display: flex;
      justify-content: space-between;
      font-size: 0.73rem;
      color: var(--muted);
    }

    .bloco-cond { display: none; }
    .bloco-cond.visivel { display: block; }

    .divider { border: none; border-top: 1px solid var(--border); margin: 26px 0; }

    .sub-titulo {
      font-size: 1.05rem;
      color: var(--primary);
      font-weight: 700;
      line-height: 1.35;
      margin-bottom: 6px;
    }

    .nav-row {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 12px 28px;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      border: none;
      transition: opacity 0.18s, transform 0.12s;
      font-family: inherit;
    }

    .btn:hover { opacity: 0.87; transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }

    .btn-primary {
      background: var(--primary);
      color: #fff;
      box-shadow: 0 4px 14px rgba(26,58,92,0.22);
    }

    .btn-ghost {
      background: transparent;
      border: 2px solid var(--border);
      color: var(--muted);
    }

    .disc-inner { text-align: center; padding: 20px 0; }
    .disc-icon { font-size: 2.8rem; margin-bottom: 16px; }

    /* ══ LOADING ══ */
    #loading {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(18,40,64,0.78);
      z-index: 999;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 18px;
    }

    #loading.ativo { display: flex; }

    .spinner {
      width: 46px; height: 46px;
      border: 4px solid rgba(255,255,255,0.15);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }

    @keyframes spin { to { transform: rotate(360deg); } }
    #loading p { color: rgba(255,255,255,0.68); font-size: 0.9rem; }

    /* ══ ENCERRAMENTO ══ */
    #tela-encerramento {
      min-height: 100vh;
      justify-content: center;
      padding: 40px 20px;
      background: linear-gradient(145deg, var(--primary-dark) 0%, var(--primary) 60%, #2a5a8c 100%);
      position: relative;
      overflow: hidden;
      text-align: center;
    }

    #tela-encerramento::before {
      content: '';
      position: absolute;
      width: 520px; height: 520px;
      border-radius: 50%;
      background: rgba(201,168,76,0.07);
      top: -180px; right: -100px;
      pointer-events: none;
    }

    .enc-inner {
      position: relative;
      z-index: 1;
      max-width: 540px;
      width: 100%;
    }

    .enc-check {
      width: 84px; height: 84px;
      background: linear-gradient(135deg, var(--accent), #e8c870);
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 30px;
      font-size: 38px;
      box-shadow: 0 10px 36px rgba(201,168,76,0.44);
      animation: popIn 0.55s cubic-bezier(.175,.885,.32,1.275);
    }

    @keyframes popIn {
      from { transform: scale(0); opacity: 0; }
      to   { transform: scale(1); opacity: 1; }
    }

    .enc-inner h2 {
      font-size: clamp(1.55rem, 4vw, 2.2rem);
      color: #fff;
      font-weight: 800;
      margin-bottom: 18px;
      line-height: 1.2;
    }

    .enc-msg {
      font-size: 1rem;
      color: rgba(255,255,255,0.73);
      line-height: 1.78;
      margin-bottom: 32px;
    }

    .enc-msg strong { color: var(--accent); }

    .enc-privacy {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.13);
      border-radius: 10px;
      padding: 12px 22px;
      font-size: 0.81rem;
      color: rgba(255,255,255,0.48);
      margin-bottom: 34px;
    }

    .btn-obrigado {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: linear-gradient(135deg, var(--accent), #e8c870);
      color: var(--primary-dark);
      font-size: 1rem;
      font-weight: 700;
      padding: 16px 48px;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      box-shadow: 0 8px 28px rgba(201,168,76,0.42);
      transition: transform 0.2s, box-shadow 0.2s;
      font-family: inherit;
    }

    .btn-obrigado:hover {
      transform: translateY(-2px);
      box-shadow: 0 14px 38px rgba(201,168,76,0.52);
    }

    @media (max-width: 560px) {
      .card { padding: 26px 18px; }
      .scale-btn { width: 38px; height: 38px; font-size: 0.82rem; }
      .bv-features { flex-direction: column; align-items: center; gap: 14px; }
    }
  </style>
</head>
<body>

<!-- LOADING -->
<div id="loading">
  <div class="spinner"></div>
  <p>Enviando suas respostas…</p>
</div>

<!-- ════════════════════════════
     TELA 1 — BOAS-VINDAS
════════════════════════════ -->
<div id="tela-boas-vindas" class="tela ativa">
  <div class="bv-inner">
    <div class="bv-logo">⚖️</div>
    <div class="bv-badge">Diagnóstico Tributário Gratuito</div>
    <h1>Quanto sua empresa pode <span>recuperar</span> em tributos?</h1>
    <p class="bv-sub">Responda de 1 a 7 perguntas e descubra quais teses tributárias se aplicam ao seu perfil — e quanto sua empresa pode recuperar.</p>
    <div class="bv-features">
      <div class="bv-feature"><span class="dot"></span>100% gratuito e sem compromisso</div>
      <div class="bv-feature"><span class="dot"></span>Resultado em menos de 3 minutos</div>
      <div class="bv-feature"><span class="dot"></span>Avaliação por especialistas</div>
    </div>
    <button class="btn-iniciar" onclick="iniciar()">Iniciar Diagnóstico →</button>
    <p class="bv-disclaimer">Seus dados são protegidos e utilizados exclusivamente para fins de diagnóstico.</p>
  </div>
</div>

<!-- ════════════════════════════
     TELA 2 — FORMULÁRIO
════════════════════════════ -->
<div id="tela-formulario" class="tela">

  <div class="form-topbar">
    <span class="dot-gold"></span>
    Diagnóstico Tributário
  </div>

  <div class="progress-wrap">
    <div class="progress-meta">
      <span id="prog-label">Identificação</span>
      <span id="prog-pct">10%</span>
    </div>
    <div class="progress-bar">
      <div class="progress-fill" id="prog-fill"></div>
    </div>
  </div>

  <div class="card">

    <!-- STEP 0 — Contato -->
    <div class="step ativo" id="s0">
      <div class="step-tag">Etapa 1 · Identificação</div>
      <h2>Antes de começar, precisamos de algumas informações</h2>
      <p class="hint">Seus dados serão utilizados exclusivamente para que nossa equipe entre em contato com os resultados do diagnóstico.</p>

      <div class="input-group">
        <label for="f-nome">Nome completo<span class="req"> *</span></label>
        <input class="field-input" type="text" id="f-nome" placeholder="Ex.: João da Silva" autocomplete="name"/>
        <span class="field-error" id="e-nome">Por favor, informe seu nome completo.</span>
      </div>

      <div class="input-group">
        <label for="f-wpp">WhatsApp<span class="req"> *</span></label>
        <input class="field-input" type="tel" id="f-wpp" placeholder="(11) 99999-9999" autocomplete="tel"/>
        <span class="field-error" id="e-wpp">Por favor, informe um número de WhatsApp válido.</span>
      </div>

      <div class="input-group">
        <label for="f-email">E-mail<span class="opt"> (opcional)</span></label>
        <input class="field-input" type="email" id="f-email" placeholder="seu@email.com" autocomplete="email"/>
      </div>

      <div class="nav-row">
        <button class="btn btn-primary" onclick="avancarS0()">Continuar →</button>
      </div>
    </div>

    <!-- STEP 1 — Natureza Jurídica -->
    <div class="step" id="s1">
      <div class="step-tag">Etapa 2 · Qualificação Inicial</div>
      <h2>Qual é a natureza jurídica do seu negócio?</h2>
      <p class="hint">Essa informação determina quais categorias de teses são estruturalmente aplicáveis ao seu caso.</p>
      <div class="options">
        <button class="option-btn" data-val="PF" onclick="pick(this,'natureza')">
          <span class="opt-radio"></span>Pessoa Física — Autônomo / Profissional Liberal
        </button>
        <button class="option-btn" data-val="ME" onclick="pick(this,'natureza')">
          <span class="opt-radio"></span>Microempresa ou EPP
        </button>
        <button class="option-btn" data-val="MG" onclick="pick(this,'natureza')">
          <span class="opt-radio"></span>Empresa de Médio ou Grande Porte
        </button>
      </div>
      <div class="nav-row">
        <button class="btn btn-ghost" onclick="ir('s0',10,'Identificação')">← Voltar</button>
        <button class="btn btn-primary" onclick="avancarS1()">Continuar →</button>
      </div>
    </div>

    <!-- STEP 1B — Nome da Empresa -->
    <div class="step" id="s1b">
      <div class="step-tag">Etapa 2 · Qualificação Inicial</div>
      <h2>Qual é o nome da sua empresa?</h2>
      <p class="hint">Informe a razão social ou o nome fantasia pelo qual a empresa é conhecida.</p>
      <div class="input-group">
        <label for="f-empresa">Nome da empresa<span class="req"> *</span></label>
        <input class="field-input" type="text" id="f-empresa" placeholder="Ex.: Comércio Silva Ltda."/>
        <span class="field-error" id="e-empresa">Por favor, informe o nome da empresa.</span>
      </div>
      <div class="nav-row">
        <button class="btn btn-ghost" onclick="ir('s1',22,'Qualificação Inicial')">← Voltar</button>
        <button class="btn btn-primary" onclick="avancarS1B()">Continuar →</button>
      </div>
    </div>

    <!-- STEP 2 — Insatisfação -->
    <div class="step" id="s2">
      <div class="step-tag">Etapa 3 · Nível de Insatisfação</div>
      <h2>Qual é o seu nível de insatisfação com a carga tributária atual?</h2>
      <p class="hint">Em uma escala de 1 (nenhuma insatisfação) a 10 (situação crítica).</p>
      <div class="scale-wrap">
        <div class="scale-buttons" id="scale-btns"></div>
        <div class="scale-legend">
          <span>1 — Nenhuma insatisfação</span>
          <span>10 — Situação crítica</span>
        </div>
      </div>
      <div class="nav-row">
        <button class="btn btn-ghost" onclick="ir('s1b',32,'Dados da Empresa')">← Voltar</button>
        <button class="btn btn-primary" onclick="avancarS2()">Continuar →</button>
      </div>
    </div>

    <!-- STEP 3 — Regime Tributário -->
    <div class="step" id="s3">
      <div class="step-tag">Etapa 4 · Regime Tributário</div>
      <h2>Qual é o regime tributário da sua empresa?</h2>
      <p class="hint">O regime define quais teses são estruturalmente elegíveis ao seu perfil.</p>
      <div class="options">
        <button class="option-btn" data-val="SN" onclick="pick(this,'regime')">
          <span class="opt-radio"></span>Simples Nacional
        </button>
        <button class="option-btn" data-val="LP" onclick="pick(this,'regime')">
