<script>
  // ── ENDPOINT ──────────────────────────────────
  const ENDPOINT = 'https://script.google.com/macros/s/AKfycbwlKZExSgaiavIg5Ily55kaZzJRGKKppshJK8azRDCKfrm4nOeWB2UslZy9jBxJVAwLKg/exec';

  // ── ESTADO ────────────────────────────────────
  const D = {
    nome:'', whatsapp:'', email:'', empresa:'',
    natureza:null, insatisfacao:null,
    regime:null, setor:null,
    faturamento:null, distribuiLucros:null, produtorRural:null,
    interestaduais:null, pd:null, combustivel:null, clinica:null
  };

  // ── CATÁLOGO DE TESES ─────────────────────────
  const TESES = {
    1: 'Adicional 10% — Lucro Distribuído > R$ 50k/mês (Simples Nacional)',
    2: 'Adicional 10% — Presunção de Faturamento > R$ 5M (Lucro Presumido)',
    3: 'INSS Acima do Teto — Pessoa Física Autônoma / Profissional Liberal',
    4: 'ICMS-ST — Portaria CAT 42/SP (Operações em SP sujeitas a ST)',
    5: 'Salário Educação — Produtor Rural Pessoa Física com Empregados',
    6: 'Créditos PIS/COFINS — Construção Civil',
    7: 'Simples Nacional Monofásico — Combustíveis, Energia, Bebidas, Cigarros',
    8: 'Exclusão do ICMS da Base de Cálculo do PIS/COFINS (Lucro Real)',
    9: 'Exclusão do ISSQN da Base de Cálculo do PIS/COFINS (Lucro Real)',
    10:'Exclusão do ICMS-ST e DIFAL da Base do PIS/COFINS',
    11:'Exclusão de Créditos Presumidos de ICMS da Base do PIS/COFINS',
    12:'Créditos PIS/COFINS — Insumos Não-Cumulativos (Lucro Real)',
    13:'Verbas Indenizatórias — Exclusão da Base de Cálculo do INSS',
    14:'IRPJ/CSLL — JSCP Extemporâneo',
    15:'IRPJ/CSLL — Subvenções de ICMS até 2023',
    16:'IRPJ/CSLL — Lei do Bem (P&D e Inovação Tecnológica)',
    17:'Créditos PIS/COFINS Diesel — Distribuidoras de Combustíveis',
    18:'IRPJ/CSLL — Clínicas Médicas e Consultórios Odontológicos',
    19:'Créditos Presumidos PIS/COFINS — Agronegócio',
    20:'Créditos Escriturais de IPI — Indústria'
  };

  // ── PIXEL — HELPER ────────────────────────────
  function pixel(evento, params) {
    if (typeof fbq === 'function') {
      if (params) fbq('track', evento, params);
      else fbq('track', evento);
    }
  }

  // ── CONTROLE DE TELAS ─────────────────────────
  function mostrarTela(id) {
    document.querySelectorAll('.tela').forEach(t => t.classList.remove('ativa'));
    document.getElementById(id).classList.add('ativa');
    window.scrollTo({ top:0, behavior:'smooth' });
  }

  function iniciar() {
    // PIXEL: usuário clicou em Iniciar Diagnóstico
    pixel('ViewContent', { content_name: 'Diagnóstico Tributário', content_category: 'Funil' });
    mostrarTela('tela-formulario');
    ir('s0', 10, 'Identificação');
  }

  // ── CONTROLE DE STEPS ─────────────────────────
  function ir(stepId, pct, label) {
    document.querySelectorAll('.step').forEach(s => s.classList.remove('ativo'));
    document.getElementById(stepId).classList.add('ativo');
    document.getElementById('prog-fill').style.width = pct + '%';
    document.getElementById('prog-pct').textContent = pct + '%';
    document.getElementById('prog-label').textContent = label;
    window.scrollTo({ top:0, behavior:'smooth' });
  }

  // ── ESCALA ────────────────────────────────────
  (function buildScale() {
    const wrap = document.getElementById('scale-btns');
    for (let i = 1; i <= 10; i++) {
      const b = document.createElement('button');
      b.type = 'button';
      b.className = 'scale-btn';
      b.textContent = i;
      b.dataset.val = i;
      b.onclick = function() {
        document.querySelectorAll('.scale-btn')
          .forEach(x => x.classList.remove('sl','sw','sh'));
        const v = parseInt(this.dataset.val);
        D.insatisfacao = v;
        this.classList.add(v <= 3 ? 'sl' : v <= 6 ? 'sw' : 'sh');
      };
      wrap.appendChild(b);
    }
  })();

  // ── SELEÇÃO DE OPÇÕES ─────────────────────────
  function pick(btn, campo) {
    btn.closest('.options').querySelectorAll('.option-btn')
      .forEach(b => b.classList.remove('sel'));
    btn.classList.add('sel');
    D[campo] = btn.dataset.val;

    if (campo === 'setor') {
      const rural = document.getElementById('bloco-rural-sn');
      if (rural) rural.classList.toggle('visivel', D.setor === 'AGR');
      const comb = document.getElementById('bloco-combustivel');
      if (comb) comb.classList.toggle('visivel', D.setor === 'COM');
    }
  }

  // ── VALIDAÇÕES ────────────────────────────────
  function setErro(inputId, errId, show) {
    document.getElementById(inputId).classList.toggle('erro', show);
    document.getElementById(errId).classList.toggle('visivel', show);
  }

  // ── NAVEGAÇÃO ─────────────────────────────────
  function avancarS0() {
    const nome = document.getElementById('f-nome').value.trim();
    const wpp  = document.getElementById('f-wpp').value.trim();
    let ok = true;
    if (!nome) { setErro('f-nome','e-nome',true); ok=false; }
    else setErro('f-nome','e-nome',false);
    if (!wpp || wpp.replace(/\D/g,'').length < 10) {
      setErro('f-wpp','e-wpp',true); ok=false;
    } else setErro('f-wpp','e-wpp',false);
    if (!ok) return;
    D.nome    = nome;
    D.whatsapp = wpp;
    D.email   = document.getElementById('f-email').value.trim();

    // PIXEL: dados de contato preenchidos — início real do funil
    pixel('InitiateCheckout', { content_name: 'Funil Tributário — Etapa Contato' });

    ir('s1', 22, 'Qualificação Inicial');
  }

  function avancarS1() {
    if (!D.natureza) { alert('Por favor, selecione uma opção.'); return; }
    if (D.natureza === 'PF') {
      ir('s4', 70, 'Setor de Atuação');
    } else {
      ir('s1b', 32, 'Dados da Empresa');
    }
  }

  function avancarS1B() {
    const emp = document.getElementById('f-empresa').value.trim();
    if (!emp) { setErro('f-empresa','e-empresa',true); return; }
    setErro('f-empresa','e-empresa',false);
    D.empresa = emp;
    ir('s2', 42, 'Nível de Insatisfação');
  }

  function avancarS2() {
    if (!D.insatisfacao) { alert('Por favor, selecione um valor na escala.'); return; }
    if (D.insatisfacao <= 3) {
      // PIXEL: lead desqualificado — ainda registra como interesse baixo
      pixel('CustomEvent', { content_name: 'Lead Desqualificado', value: D.insatisfacao });
      ir('s-disc', 30, 'Encerrado');
    } else {
      ir('s3', 56, 'Regime Tributário');
    }
  }

  function avancarS3() {
    if (!D.regime) { alert('Por favor, selecione o regime tributário.'); return; }
    ir('s4', 70, 'Setor de Atuação');
  }

  function voltarS4() {
    if (D.natureza === 'PF') ir('s1', 22, 'Qualificação Inicial');
    else ir('s3', 56, 'Regime Tributário');
  }

  function avancarS4() {
    if (!D.setor) { alert('Por favor, selecione o setor de atuação.'); return; }

    if (D.natureza === 'PF') {
      if (D.setor === 'AGR') ir('s5g', 86, 'Perguntas Condicionais');
      else enviar();
      return;
    }

    if (D.regime === 'SN') {
      document.getElementById('bloco-rural-sn')
        .classList.toggle('visivel', D.setor === 'AGR');
      ir('s5b', 86, 'Perguntas Condicionais');
      return;
    }

    if (D.regime === 'LP') {
      if (D.setor === 'SAU') ir('s5f', 86, 'Perguntas Condicionais');
      else ir('s5a', 86, 'Perguntas Condicionais');
      return;
    }

    if (D.regime === 'LR') {
      document.getElementById('bloco-combustivel')
        .classList.toggle('visivel', D.setor === 'COM');
      ir('s5cde', 86, 'Perguntas Condicionais');
    }
  }

  // ── CÁLCULO DE TESES ──────────────────────────
  function calcularTeses() {
    const t = new Set();

    if (D.natureza === 'PF') {
      t.add(3); t.add(13);
      if (D.produtorRural === 'SIM') t.add(5);
      return t;
    }

    if (D.regime === 'SN') {
      t.add(1); t.add(7);
      if (D.distribuiLucros === 'NAO') t.delete(1);
      if (D.setor === 'AGR' && D.produtorRural === 'SIM') t.add(5);
      return t;
    }

    if (D.regime === 'LP') {
      t.add(2); t.add(4); t.add(6); t.add(18);
      if (D.setor === 'COM' || D.setor === 'IND') {
        t.delete(18);
      } else if (D.setor === 'CON') {
        t.delete(18);
      } else if (D.setor === 'SAU') {
        t.delete(6);
        if (D.clinica !== 'SIM') t.delete(18);
      } else {
        t.delete(6); t.delete(18);
      }
      if (D.faturamento === 'ATE5') t.delete(2);
      return t;
    }

    if (D.regime === 'LR') {
      t.add(8); t.add(9); t.add(10); t.add(11);
      t.add(12); t.add(13); t.add(14); t.add(15); t.add(16);

      if (D.setor === 'COM') {
        t.delete(9); t.delete(15);
      } else if (D.setor === 'IND') {
        t.delete(9); t.delete(15); t.add(20);
      } else if (D.setor === 'CON') {
        t.delete(9); t.delete(15);
      } else if (D.setor === 'SRV') {
        t.delete(8); t.delete(15);
      } else if (D.setor === 'AGR') {
        t.delete(9); t.add(19);
      } else {
        t.delete(9); t.delete(15);
      }

      if (D.interestaduais === 'NAO') { t.delete(10); t.delete(11); }
      if (D.pd === 'NAO') t.delete(16);
      if (D.setor === 'COM' && D.combustivel === 'SIM') t.add(17);
    }

    return t;
  }

  // ── LABELS ────────────────────────────────────
  const LBL = {
    natureza: { PF:'Pessoa Física', ME:'ME / EPP', MG:'Médio / Grande Porte' },
    regime:   { SN:'Simples Nacional', LP:'Lucro Presumido', LR:'Lucro Real' },
    setor:    { COM:'Comércio', IND:'Indústria', CON:'Construção Civil',
                SRV:'Serviços', SAU:'Saúde', AGR:'Agronegócio', OUT:'Outro' },
    fat:      { ATE5:'Até R$ 5M', ACIMA5:'Acima de R$ 5M' },
    bool:     { SIM:'Sim', NAO:'Não', OCL:'Ocasionalmente' }
  };

  function lbl(obj, val) {
    return (obj && val) ? (obj[val] || '—') : '—';
  }

  function temperatura() {
    if (!D.insatisfacao) return 'N/A';
    return D.insatisfacao >= 7 ? 'Hot Lead' : 'Warm Lead';
  }

  function potencial(n) {
    return n >= 5 ? 'ALTO' : n >= 3 ? 'MÉDIO' : 'BAIXO';
  }

  // ── VALIDAÇÃO FINAL ───────────────────────────
  function validarFinal() {
    if (D.regime === 'SN') {
      if (!D.distribuiLucros) {
        alert('Por favor, responda se a empresa distribui lucros.'); return false;
      }
      if (D.setor === 'AGR' && !D.produtorRural) {
        alert('Por favor, responda a pergunta sobre produtor rural.'); return false;
      }
    }
    if (D.regime === 'LP') {
      if (!D.faturamento) {
        alert('Por favor, selecione o faturamento.'); return false;
      }
      if (D.setor === 'SAU' && !D.clinica) {
        alert('Por favor, responda a pergunta sobre clínica/consultório.'); return false;
      }
    }
    if (D.regime === 'LR') {
      if (!D.interestaduais) {
        alert('Por favor, responda a pergunta sobre operações interestaduais.'); return false;
      }
      if (!D.pd) {
        alert('Por favor, responda a pergunta sobre pesquisa e desenvolvimento.'); return false;
      }
      if (D.setor === 'COM' && !D.combustivel) {
        alert('Por favor, responda a pergunta sobre distribuição de combustíveis.'); return false;
      }
    }
    if (D.natureza === 'PF' && D.setor === 'AGR' && !D.produtorRural) {
      alert('Por favor, responda a pergunta sobre produtor rural.'); return false;
    }
    return true;
  }

    // ── PAYLOAD ───────────────────────────────────
  function montarPayload(teses, pot) {
    const lista = [...teses].sort((a,b) => a-b)
      .map(n => '#' + n + ' — ' + TESES[n]).join(' | ');
    return {
      nome:            D.nome,
      whatsapp:        D.whatsapp,
      email:           D.email || '—',
      empresa:         D.empresa || '—',
      natureza:        lbl(LBL.natureza, D.natureza),
      insatisfacao:    D.insatisfacao ? D.insatisfacao + '/10' : '—',
      temperatura:     temperatura(),
      regime:          lbl(LBL.regime, D.regime),
      setor:           lbl(LBL.setor, D.setor),
      faturamento:     lbl(LBL.fat, D.faturamento),
      distribuiLucros: lbl(LBL.bool, D.distribuiLucros),
      produtorRural:   lbl(LBL.bool, D.produtorRural),
      interestaduais:  lbl(LBL.bool, D.interestaduais),
      pd:              lbl(LBL.bool, D.pd),
      combustivel:     lbl(LBL.bool, D.combustivel),
      clinica:         lbl(LBL.bool, D.clinica),
      teses:           lista,
      potencial:       pot
    };
  }

  // ── ENVIO PRINCIPAL ───────────────────────────
  function enviar() {
    if (!validarFinal()) return;

    const teses   = calcularTeses();
    const pot     = potencial(teses.size);
    const payload = montarPayload(teses, pot);

    // PIXEL: Lead qualificado — evento mais importante para otimização
    pixel('Lead', {
      content_name:     'Diagnóstico Tributário Concluído',
      content_category: D.regime ? lbl(LBL.regime, D.regime) : 'Pessoa Física',
      value:            teses.size,
      currency:         'BRL',
      status:           pot
    });

    // Exibe loading
    document.getElementById('loading').classList.add('ativo');

    fetch(ENDPOINT, {
      method:  'POST',
      mode:    'no-cors',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload)
    })
    .then(() => {
      document.getElementById('loading').classList.remove('ativo');
      mostrarTela('tela-encerramento');
    })
    .catch(() => {
      document.getElementById('loading').classList.remove('ativo');
      mostrarTela('tela-encerramento');
    });
  }

  // ── REINICIAR ─────────────────────────────────
  function reiniciar() {
    // Limpa estado
    Object.keys(D).forEach(k => D[k] = null);
    D.nome = ''; D.whatsapp = ''; D.email = ''; D.empresa = '';

    // Limpa campos de texto
    ['f-nome','f-wpp','f-email','f-empresa'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.value = '';
    });

    // Limpa erros
    document.querySelectorAll('.field-input')
      .forEach(el => el.classList.remove('erro'));
    document.querySelectorAll('.field-error')
      .forEach(el => el.classList.remove('visivel'));

    // Limpa seleções
    document.querySelectorAll('.option-btn')
      .forEach(b => b.classList.remove('sel'));

    // Limpa escala
    document.querySelectorAll('.scale-btn')
      .forEach(b => b.classList.remove('sl','sw','sh'));

    // Oculta blocos condicionais
    ['bloco-rural-sn','bloco-combustivel'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.remove('visivel');
    });

    // Volta para tela inicial
    mostrarTela('tela-boas-vindas');
  }

</script>
